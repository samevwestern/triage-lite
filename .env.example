# ✦ TRIAGE LITE - MOBILE ENV CONFIGURATION
# Copy this file to '.env' inside 'triage-lite/' folder.

# ------------------------------------------------------------------------------
# 1. SERVER CONFIGURATION
# ------------------------------------------------------------------------------
# Set to 'http://localhost:3000' for local dev simulation.
# For physical iOS device testing, this MUST point to your Mac's local network IP
# (e.g. http://192.168.1.104:3000) or your production secure Cloud Run domain.
VITE_BACKEND_BASE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# 2. FIREBASE OAUTH CLIENT KEYS
# ------------------------------------------------------------------------------
# These keys are parsed on compilation by Vite.
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# ------------------------------------------------------------------------------
# 3. IOS DEVICE CONFIGURATIONS
# ------------------------------------------------------------------------------
# Set to true to bypass active Firebase network auth in simulator tests.
VITE_BYPASS_AUTH_FOR_DEV_SIMULATOR=false
